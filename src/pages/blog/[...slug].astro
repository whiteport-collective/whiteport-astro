---
import { getCollection, render } from 'astro:content';
import SocialStreamPostLayout from '../../layouts/SocialStreamPost.astro';
import RelatedPostsGrid from '../../components/social-stream/RelatedPostsGrid.astro';
import { getVisibleBlogPosts, collectTags, resolveMediaSrc } from '../../utils/content-helpers';
import { SERVICES } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts
		.filter((post) => !post.data.draft)
		.map((post) => ({
			params: { slug: post.id },
			props: post,
		}));
}

const post = Astro.props;
const { Content } = await render(post);
const { title, publishDate, author, categories, locations, mentions, gallery, creativeNote, socialPosts, tags, offers: manualOffers } = post.data;

// Compute previous/next posts
const allBlog = await getCollection('blog');
const sorted = getVisibleBlogPosts(allBlog);
const currentIndex = sorted.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const prevPost2 = currentIndex < sorted.length - 2 ? sorted[currentIndex + 2] : null;
const nextPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const nextPost2 = currentIndex > 1 ? sorted[currentIndex - 2] : null;

// Build share URL
const shareUrl = new URL(`/blog/${post.id}/`, Astro.site).href;

// Match gallery images to social platforms via display[] field
const platformImages = new Map<string, string>();
if (gallery && socialPosts) {
  for (const sp of socialPosts) {
    const match = gallery.find(g => g.display?.includes(sp.platform));
    if (match) {
      platformImages.set(sp.platform, resolveMediaSrc(match));
    }
  }
}

// Compute sidebar offers: manual override → auto-match by tags → WDS fallback
const allTags = [...(categories || []), ...(tags || [])];
const computedOffers = manualOffers || SERVICES
  .filter(s => s.tags.some(t => allTags.includes(t)))
  .slice(0, 2)
  .map(s => ({ title: s.title, description: s.description, href: s.href }));

// Related posts data
const relatedPosts = sorted.filter(p => p.id !== post.id);
const tagCounts = collectTags(relatedPosts);
const primaryCategory = categories?.[0] || '';
---

<SocialStreamPostLayout
  title={title}
  publishDate={publishDate}
  author={author}
  categories={categories}
  locations={locations}
  mentions={mentions}
  gallery={gallery}
  creativeNote={creativeNote}
  offers={computedOffers}
  allTags={allTags}
>
  <Content />

  <!-- Social platform links with device images -->
  <Fragment slot="after-content">
    {socialPosts && socialPosts.length > 0 && (
      <div class="mt-8 pt-6 border-t border-gray-100">
        <p class="text-sm font-medium text-wp-grey mb-3">Also posted on:</p>
        <div class="flex flex-col gap-3">
          {socialPosts.map((sp) => {
            const platformImg = platformImages.get(sp.platform);
            return (
              <details class="group published-also-item">
                <summary class="cursor-pointer list-none flex items-center gap-2">
                  <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full bg-wp-section-bg text-wp-grey group-open:bg-wp-blue/10 group-open:text-wp-blue transition-colors">
                    {sp.platform === 'instagram' && (
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                    )}
                    {sp.platform === 'facebook' && (
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    )}
                    {sp.platform === 'linkedin' && (
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    )}
                    {sp.platform === 'tiktok' && (
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                    )}
                    {sp.platform === 'youtube' && (
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    )}
                    {sp.platform}
                    <svg class="w-3 h-3 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg>
                  </span>
                </summary>
                <div class="mt-3 ml-1">
                  {platformImg && (
                    <img src={platformImg} alt={`${sp.platform} version`} class="rounded-lg max-w-sm w-full mb-3" loading="lazy" />
                  )}
                  {sp.url && (
                    <a href={sp.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm text-wp-blue hover:underline no-underline">
                      View on {sp.platform} &rarr;
                    </a>
                  )}
                </div>
              </details>
            );
          })}
        </div>
      </div>
    )}

  </Fragment>

  <!-- Share buttons in sidebar -->
  <Fragment slot="sidebar-share">
    <div class="pt-2">
      <p style="font-size:14px;" class="font-medium text-wp-grey mb-3">Share this post:</p>
      <div class="flex gap-2">
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-full bg-wp-section-bg flex items-center justify-center text-wp-grey hover:bg-wp-blue hover:text-white transition-colors no-underline"
          aria-label="Share on LinkedIn"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a
          href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-full bg-wp-section-bg flex items-center justify-center text-wp-grey hover:bg-wp-blue hover:text-white transition-colors no-underline"
          aria-label="Share on Facebook"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a
          href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(title)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-full bg-wp-section-bg flex items-center justify-center text-wp-grey hover:bg-wp-blue hover:text-white transition-colors no-underline"
          aria-label="Share on X"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <button
          class="w-9 h-9 rounded-full bg-wp-section-bg flex items-center justify-center text-wp-grey hover:bg-wp-blue hover:text-white transition-colors copy-url-btn"
          data-url={shareUrl}
          aria-label="Copy link"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-3.03a4.5 4.5 0 0 0-1.242-7.244l-4.5-4.5a4.5 4.5 0 0 0-6.364 6.364l1.757 1.757" /></svg>
        </button>
      </div>
    </div>
  </Fragment>

  <!-- Post navigation — inside article column via after-content-nav slot -->
  <Fragment slot="after-content-nav">
    {(prevPost || nextPost) && (() => {
      const navLabel = (p: typeof prevPost) => {
        if (!p) return '';
        const shared = [...(p.data.categories || []), ...(p.data.tags || [])]
          .find(t => allTags.includes(t));
        return shared ? `More on ${shared}` : 'Read more';
      };
      return (
      <nav class="mt-8">
        <div class="flex gap-6">
          {prevPost ? (
            <a href={`/blog/${prevPost.id}/`} class="group block p-4 rounded-lg hover:bg-wp-section-bg transition-colors no-underline flex-1">
              <span class="text-sm text-wp-grey">{navLabel(prevPost)}</span>
              <p class="text-base font-medium group-hover:text-wp-blue transition-colors line-clamp-2 mt-1">{prevPost.data.title}</p>
            </a>
          ) : nextPost2 ? (
            <a href={`/blog/${nextPost2.id}/`} class="group block p-4 rounded-lg hover:bg-wp-section-bg transition-colors no-underline flex-1">
              <span class="text-sm text-wp-grey">{navLabel(nextPost2)}</span>
              <p class="text-base font-medium group-hover:text-wp-blue transition-colors line-clamp-2 mt-1">{nextPost2.data.title}</p>
            </a>
          ) : <div class="flex-1" />}
          {nextPost ? (
            <a href={`/blog/${nextPost.id}/`} class="group block p-4 rounded-lg hover:bg-wp-section-bg transition-colors no-underline flex-1">
              <span class="text-sm text-wp-grey">{navLabel(nextPost)}</span>
              <p class="text-base font-medium group-hover:text-wp-blue transition-colors line-clamp-2 mt-1">{nextPost.data.title}</p>
            </a>
          ) : prevPost2 ? (
            <a href={`/blog/${prevPost2.id}/`} class="group block p-4 rounded-lg hover:bg-wp-section-bg transition-colors no-underline flex-1">
              <span class="text-sm text-wp-grey">{navLabel(prevPost2)}</span>
              <p class="text-base font-medium group-hover:text-wp-blue transition-colors line-clamp-2 mt-1">{prevPost2.data.title}</p>
            </a>
          ) : <div class="flex-1" />}
        </div>
      </nav>
      );
    })()}
  </Fragment>

  <Fragment slot="below-main">
    <!-- Related posts grid -->
    <RelatedPostsGrid
      posts={relatedPosts}
      tagCounts={tagCounts}
      activeCategory={primaryCategory}
      currentPostId={post.id}
      currentTags={allTags}
    />
  </Fragment>
</SocialStreamPostLayout>

<script>
  document.querySelectorAll('.copy-url-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const url = (btn as HTMLElement).dataset.url;
      if (url) {
        await navigator.clipboard.writeText(url);
        const svg = btn.querySelector('svg');
        if (svg) {
          svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />';
          setTimeout(() => {
            svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m9.86-3.03a4.5 4.5 0 0 0-1.242-7.244l-4.5-4.5a4.5 4.5 0 0 0-6.364 6.364l1.757 1.757" />';
          }, 2000);
        }
      }
    });
  });
</script>
