---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}

const project = Astro.props;
const { Content } = await render(project);
const { title, description, client, tags, blocks, url } = project.data;

const hasBlocks = blocks && blocks.length > 0;
const ogImage = project.data.featuredImage?.src || undefined;

// Previous/next projects
const allProjects = await getCollection('projects');
const projects = allProjects.filter((p) => !p.data.draft);
const currentIndex = projects.findIndex((p) => p.id === project.id);
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : null;
const nextProject = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : null;
---

<BaseLayout
  title={title}
  description={description || `${title} — a Whiteport project`}
  image={ogImage}
  type="article"
  headerSolid={true}
>
  <article class="project-article">
    {/* Breadcrumb */}
    <nav class="breadcrumb page-width" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">&gt;</span>
      <a href="/projects/">Projects</a>
      <span class="sep">&gt;</span>
      <span class="current">{title}</span>
    </nav>

    {hasBlocks ? (
      /* === BLOCK-BASED LAYOUT (WP-style) === */
      blocks.map((block) => {
        if (block.type === 'content-image') {
          return (
            <section class:list={[
              'content-image-block',
              { 'reverse': block.reverse },
              { 'highlighted': block.highlighted },
            ]}>
              <div class="content-image-block__wrapper page-width">
                <div class="content-image-block__content">
                  {block.heading && (
                    block.highlighted
                      ? <h1>{block.heading}</h1>
                      : <h2>{block.heading}</h2>
                  )}
                  {block.text.split('\n\n').map((para) => (
                    <p set:html={para
                      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                      .replace(/\*(.+?)\*/g, '<em>$1</em>')
                    } />
                  ))}
                  {block.list && block.list.length > 0 && (
                    <ul>
                      {block.list.map((item) => <li>{item}</li>)}
                    </ul>
                  )}
                </div>
                <div class="content-image-block__media">
                  <img
                    src={block.image.src}
                    alt={block.image.alt || title}
                    class={block.image.size === 'banner' ? 'size-banner' : 'size-large'}
                    loading="lazy"
                  />
                </div>
              </div>
            </section>
          );
        }

        if (block.type === 'poster') {
          return (
            <section class:list={['poster-block', { 'full': block.full }]}>
              {block.full ? (
                <img
                  src={block.image.src}
                  alt={block.image.alt || title}
                  class="poster-img"
                  loading="lazy"
                />
              ) : (
                <div class="page-width">
                  <img
                    src={block.image.src}
                    alt={block.image.alt || title}
                    class="poster-img"
                    loading="lazy"
                  />
                </div>
              )}
            </section>
          );
        }

        if (block.type === 'testimonial') {
          return (
            <section class="testimonials-block">
              <div class="testimonials-block__wrapper page-width">
                <h2>{block.heading}</h2>
                <div class="testimonials-block__item">
                  {block.avatar && (
                    <div class="testimonials-block__image">
                      <img src={block.avatar} alt={block.name} loading="lazy" />
                    </div>
                  )}
                  <div class="testimonials-block__text">
                    <div class="testimonials-block__icon" aria-hidden="true">&ldquo;</div>
                    <p class="testimonials-block__quote">{block.quote}</p>
                    <p class="testimonials-block__name">{block.name}</p>
                    {block.role && <p class="testimonials-block__role">{block.role}</p>}
                  </div>
                </div>
              </div>
            </section>
          );
        }

        return null;
      })
    ) : (
      /* === FALLBACK: Markdown prose layout === */
      <div class="page-width-short prose py-12">
        <header class="mb-12">
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-light mb-4">{title}</h1>
          {description && <p class="text-lg text-wp-grey leading-relaxed">{description}</p>}
        </header>
        <Content />
      </div>
    )}

    {/* Project navigation */}
    <nav class="project-nav page-width">
      <div class="project-nav__grid">
        {prevProject ? (
          <a href={`/projects/${prevProject.id}/`} class="project-nav__link">
            <span class="project-nav__label">&larr; Previous</span>
            <span class="project-nav__title">{prevProject.data.title}</span>
          </a>
        ) : <div />}
        <div class="project-nav__center">
          <a href="/projects/">All projects</a>
        </div>
        {nextProject ? (
          <a href={`/projects/${nextProject.id}/`} class="project-nav__link project-nav__link--next">
            <span class="project-nav__label">Next &rarr;</span>
            <span class="project-nav__title">{nextProject.data.title}</span>
          </a>
        ) : <div />}
      </div>
    </nav>
  </article>
</BaseLayout>

<style>
  /* === Article — offset for fixed header === */
  .project-article {
    padding-top: 107px;
  }

  /* === Breadcrumb === */
  .breadcrumb {
    max-width: 1230px;
    margin-left: auto;
    margin-right: auto;
    padding: 30px 30px 10px;
    font-size: 13px;
    color: rgb(146, 148, 151);
    text-align: center;
  }
  .breadcrumb a {
    color: rgb(146, 148, 151);
    text-decoration: none;
  }
  .breadcrumb a:hover {
    color: rgb(60, 59, 59);
  }
  .breadcrumb .sep {
    margin: 0 6px;
  }
  .breadcrumb .current {
    color: rgb(60, 59, 59);
    font-weight: 500;
  }

  /* === Content-Image Block === */
  .content-image-block {
    margin: 56px 0;
  }
  .content-image-block__wrapper {
    display: flex;
    gap: 50px;
    align-items: center;
    max-width: 1230px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 30px;
    padding-right: 30px;
  }
  .content-image-block__content {
    flex: 1 1 0%;
    min-width: 0;
    max-width: 600px;
  }
  .content-image-block__media {
    flex: 1 1 0%;
    min-width: 0;
  }
  .content-image-block__media img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Reversed: image on left, text on right */
  .content-image-block.reverse .content-image-block__wrapper {
    flex-direction: row-reverse;
  }

  /* Typography inside content blocks */
  .content-image-block h1 {
    font-size: 36px;
    font-weight: 300;
    color: rgb(60, 59, 59);
    line-height: 1.2;
    margin-bottom: 24px;
  }
  .content-image-block h2 {
    font-size: 36px;
    font-weight: 300;
    color: rgb(60, 59, 59);
    line-height: 1.2;
    margin-bottom: 24px;
  }
  .content-image-block p {
    font-size: 18px;
    font-weight: 300;
    color: rgb(46, 46, 46);
    line-height: 30px;
    margin-bottom: 16px;
  }
  .content-image-block ul {
    list-style: disc;
    padding-left: 20px;
    margin-bottom: 16px;
  }
  .content-image-block li {
    font-size: 18px;
    font-weight: 300;
    color: rgb(46, 46, 46);
    line-height: 30px;
    margin-bottom: 4px;
  }

  /* === Poster Block === */
  .poster-block {
    margin: 56px 0;
  }
  .poster-block .page-width {
    max-width: 1230px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 30px;
    padding-right: 30px;
  }
  .poster-block .poster-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* === Testimonial Block === */
  .testimonials-block {
    margin: 56px 0;
    padding: 40px 0;
  }
  .testimonials-block__wrapper {
    max-width: 1230px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 30px;
    padding-right: 30px;
  }
  .testimonials-block h2 {
    font-size: 36px;
    font-weight: 300;
    color: rgb(46, 46, 46);
    margin-bottom: 68px;
  }
  .testimonials-block__item {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    max-width: 840px;
  }
  .testimonials-block__image {
    width: 145px;
    height: 145px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }
  .testimonials-block__image img {
    width: 145px;
    height: 145px;
    object-fit: cover;
    display: block;
  }
  .testimonials-block__icon {
    font-size: 120px;
    line-height: 0.5;
    color: rgb(120, 172, 46);
    margin-bottom: 8px;
    font-family: Georgia, serif;
  }
  .testimonials-block__quote {
    font-size: 18px;
    font-weight: 300;
    color: rgb(46, 46, 46);
    line-height: 30px;
    margin-bottom: 16px;
  }
  .testimonials-block__name {
    font-size: 16px;
    font-weight: 500;
    color: rgb(46, 46, 46);
    line-height: 19px;
    margin-bottom: 4px;
  }
  .testimonials-block__role {
    font-size: 16px;
    font-weight: 300;
    color: rgb(46, 46, 46);
    line-height: 19px;
    text-transform: uppercase;
  }

  /* === Project Navigation === */
  .project-nav {
    max-width: 1230px;
    margin-left: auto;
    margin-right: auto;
    margin-top: 64px;
    padding: 32px 30px 48px;
    border-top: 1px solid #e5e7eb;
  }
  .project-nav__grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 16px;
    align-items: start;
  }
  .project-nav__link {
    display: block;
    padding: 8px 12px;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.2s;
  }
  .project-nav__link:hover {
    background-color: var(--color-wp-section-bg, #f5f5f5);
  }
  .project-nav__link--next {
    text-align: right;
  }
  .project-nav__label {
    display: block;
    font-size: 12px;
    color: rgb(146, 148, 151);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .project-nav__title {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: rgb(60, 59, 59);
    margin-top: 4px;
  }
  .project-nav__center a {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-wp-button, #4879A7);
    text-decoration: none;
  }
  .project-nav__center a:hover {
    color: var(--color-wp-button-hover, #043F76);
  }

  /* === Mobile responsive === */
  @media (max-width: 768px) {
    .content-image-block__wrapper {
      flex-direction: column !important;
      gap: 24px;
    }
    .content-image-block h1,
    .content-image-block h2 {
      font-size: 28px;
    }
    .content-image-block p,
    .content-image-block li {
      font-size: 16px;
      line-height: 26px;
    }
    .testimonials-block__item {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .testimonials-block h2 {
      font-size: 28px;
    }
    .project-nav__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .project-nav__link--next {
      text-align: center;
    }
  }
</style>
