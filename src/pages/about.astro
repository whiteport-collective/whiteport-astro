---
import BaseLayout from '../layouts/BaseLayout.astro';
import { COMPANY, SOCIAL_LINKS, SITE_URL } from '../consts';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: 'About Whiteport',
  url: `${SITE_URL}/about/`,
  mainEntity: {
    '@type': 'Organization',
    name: COMPANY.name,
    url: SITE_URL,
    foundingDate: '2003',
    founder: { '@type': 'Person', name: COMPANY.founder },
    address: { '@type': 'PostalAddress', streetAddress: 'Klubbacken 49', postalCode: '129 39', addressLocality: 'Hägersten', addressCountry: 'SE' },
    email: COMPANY.email,
  },
};
---

<BaseLayout title="About — Digital Design Agency Since 2003" description="Whiteport was founded 2003 by Mårten Angner. We build sites, apps and e-commerce with innovative solutions, smooth interfaces and minimalistic design." jsonLd={jsonLd}>
  <!-- Hero -->
  <section class="bg-wp-blue text-white py-20 sm:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">About Whiteport</h1>
      <p class="text-lg text-white/75 max-w-3xl mx-auto leading-relaxed">
        A charming digital agency passionate about saving the world, one digital design project at a time.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose max-w-none">
        <h2 class="text-2xl sm:text-3xl font-bold mb-6">Our story</h2>
        <p class="text-wp-grey text-lg leading-relaxed mb-6">
          Whiteport was founded 2003 by Mårten Angner and has been successfully serving clients with sites, apps and e-commerce applications ever since. Whiteport is also an innovative agency exploring the boundaries of the possible by our own digital projects.
        </p>
        <p class="text-wp-grey text-lg leading-relaxed mb-6">
          We focus on innovative solutions, smooth interfaces, neat and minimalistic design and work according to our own unique development approach.
        </p>
        <p class="text-wp-grey text-lg leading-relaxed">
          Our methods unify strategic thinking, UX, visual design and AI technology — bringing structure to complexity with vision and a sharp eye for user experience.
        </p>
      </div>
    </div>
  </section>

  <!-- What we believe -->
  <section class="bg-wp-section-bg py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-16">What we believe</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="text-center px-4">
          <div class="w-16 h-16 bg-wp-blue/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-wp-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Concept & design combining vision with purpose</h3>
          <p class="text-wp-grey text-sm leading-relaxed">
            We bring structure to complexity. With vision and a sharp eye for user experience, we turn ideas into impactful designs that look and feel just right — delivering clarity, elegance, and return on investment.
          </p>
        </div>
        <div class="text-center px-4">
          <div class="w-16 h-16 bg-wp-blue/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-wp-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">Adding business sense to your digital presence</h3>
          <p class="text-wp-grey text-sm leading-relaxed">
            We combine strategic insight and real user research with a product mindset. The result? Less chaos, more clarity — and digital solutions that turn ambition into real, measurable progress.
          </p>
        </div>
        <div class="text-center px-4">
          <div class="w-16 h-16 bg-wp-blue/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-8 h-8 text-wp-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold mb-3">AI amplifies, designers lead</h3>
          <p class="text-wp-grey text-sm leading-relaxed">
            AI Agent framework for designers based on BMAD method. Gives every designer access to a free and open source platform for Digital Design, Strategy, Trigger mapping, Scenario sketching and handover to development.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Manifesto -->
  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold mb-6">The Whiteport Manifesto</h2>
      <div class="bg-white border border-gray-100 rounded-xl p-8 sm:p-12">
        <p class="text-wp-grey text-lg leading-relaxed mb-6 font-medium italic">
          "One Business One System!"
        </p>
        <p class="text-wp-grey leading-relaxed mb-4">
          Technology is becoming more and more accessible to companies and organizations, while costs and challenges with the flora of standard services are becoming more and more tangible, both practically and financially. At the same time, it has never been easier to build your own, specially developed business system perfectly adapted to the business.
        </p>
        <p class="text-wp-grey leading-relaxed">
          We carry the vision of a future where companies take back the power over the digital aspects of their business and effortlessly design, develop and optimize their own systems to secure their growth for the future!
        </p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="bg-wp-section-bg py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-center mb-12">The team</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-2xl mx-auto">
        {COMPANY.team.map((member) => (
          <div class="bg-white rounded-xl p-8 text-center">
            <div class="w-20 h-20 bg-wp-blue/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl font-bold text-wp-blue">{member.name.split(' ').map(n => n[0]).join('')}</span>
            </div>
            <h3 class="text-lg font-semibold mb-1">{member.name}</h3>
            <p class="text-sm text-wp-grey mb-4">{member.title}</p>
            <div class="space-y-1 text-sm">
              <a href={`mailto:${member.email}`} class="block text-wp-button hover:text-wp-button-hover no-underline">{member.email}</a>
              <a href={`tel:${member.phone}`} class="block text-wp-grey hover:text-wp-base no-underline">{member.phone}</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-wp-blue text-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">Let's build something together</h2>
      <p class="text-white/75 mb-8">
        Ready to transform your digital presence?
      </p>
      <a
        href="/contact/"
        class="inline-block px-10 py-4 bg-wp-cta text-white font-semibold rounded-lg hover:bg-wp-cta-hover transition-colors no-underline text-lg"
      >
        Get in touch
      </a>
    </div>
  </section>
</BaseLayout>
