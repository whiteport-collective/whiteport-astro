---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'Whiteport Design Studio (WDS)';
const description = 'Strategic design methodology for products people love. Install WDS in one prompt — no terminal, no npm.';
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <div class="prose">

        <div class="hero">
          <h1>Whiteport Design Studio</h1>
          <p class="tagline">Strategic design methodology for products people love, powered by AI agents.</p>
          <div class="install-box">
            <p class="install-label">Install — open a Claude session and type:</p>
            <pre><code>Install whiteport-design-studio from GitHub for me</code></pre>
          </div>
        </div>

        <hr />

        <h2>What is WDS?</h2>
        <p>
          WDS is a structured design methodology that guides you from product idea to developer-ready specification,
          using AI agents as collaborators. Each agent owns a phase. They hand off to each other automatically.
          You stay in the design conversation.
        </p>

        <ul>
          <li><strong>Trigger mapping</strong> — understand the psychological forces driving user behaviour</li>
          <li><strong>UX scenarios</strong> — scenario-first design: understand the journey before drawing anything</li>
          <li><strong>Design Loop</strong> — eight-step per-page cycle from spec to implemented</li>
          <li><strong>Agent coordination</strong> — agents hand off through progress files between sessions</li>
        </ul>

        <h2>Agents</h2>
        <table>
          <thead>
            <tr><th>Agent</th><th>Command</th><th>Role</th></tr>
          </thead>
          <tbody>
            <tr><td><strong>Saga</strong></td><td><code>/saga</code></td><td>Strategic analyst — Product Brief, Trigger Map</td></tr>
            <tr><td><strong>Freya</strong></td><td><code>/freya</code></td><td>UX designer — Scenarios, Design Loop, specs</td></tr>
            <tr><td><strong>Mimir</strong></td><td><code>/mimir</code></td><td>Builder — implements from Freya's specs</td></tr>
          </tbody>
        </table>

        <h2>How It Works</h2>
        <ol>
          <li>Tell Claude: <em>"Install whiteport-design-studio from GitHub for me"</em></li>
          <li>Claude installs WDS to <code>~/.claude/wds/</code> and creates slash commands</li>
          <li>Open your project in Claude and run <code>/saga</code></li>
          <li>Saga guides you through a Product Brief, Trigger Map, and hands off to Freya</li>
          <li>Freya runs the Design Loop page by page, handing off to Mimir when ready to build</li>
        </ol>

        <h2>Design Phases</h2>
        <table>
          <thead>
            <tr><th>Phase</th><th>Agent</th><th>Output</th></tr>
          </thead>
          <tbody>
            <tr><td>1. Product Brief</td><td>Saga</td><td><code>A-Product-Brief/</code></td></tr>
            <tr><td>2. Trigger Map</td><td>Saga</td><td><code>B-Trigger-Map/</code></td></tr>
            <tr><td>3. UX Scenarios</td><td>Freya</td><td><code>C-UX-Scenarios/</code></td></tr>
            <tr><td>4. UX Design</td><td>Freya</td><td><code>D-UX-Design/</code></td></tr>
            <tr><td>5. Development</td><td>Mimir</td><td>—</td></tr>
          </tbody>
        </table>

        <h2>Works in Any AI IDE</h2>
        <p>
          WDS skill files are markdown — any capable AI can follow them. Optimised for Claude Code,
          and compatible with Cursor, Windsurf, Copilot, and any IDE that supports slash commands or file-based instructions.
        </p>

        <h2>Keeping WDS Updated</h2>
        <p>Agents sync automatically on startup. To update manually:</p>
        <pre><code>/sync</code></pre>

        <div class="cta">
          <a href="https://github.com/whiteport-collective/whiteport-design-studio" target="_blank">
            View on GitHub →
          </a>
          <a href="/products/wds/docs">
            Documentation →
          </a>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    width: calc(100% - 2em);
    max-width: 100%;
    margin: 0;
  }
  .prose {
    width: 760px;
    max-width: calc(100% - 2em);
    margin: auto;
    padding: 2em 1em;
    color: rgb(var(--gray-dark));
  }
  .hero {
    padding: 2em 0 1.5em;
  }
  h1 {
    font-size: 2.2em;
    margin-bottom: 0.3em;
  }
  .tagline {
    font-size: 1.15em;
    color: rgb(var(--gray));
    margin-bottom: 1.5em;
  }
  .install-box {
    background: rgb(var(--gray-light));
    border-radius: 8px;
    padding: 1.2em 1.5em;
    margin-bottom: 1em;
    display: inline-block;
  }
  .install-label {
    font-size: 0.85em;
    color: rgb(var(--gray));
    margin: 0 0 0.5em;
  }
  .install-box pre {
    margin: 0;
    background: none;
    padding: 0;
  }
  .install-box code {
    font-size: 1em;
    font-weight: 600;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 1em 0 1.5em;
  }
  th, td {
    text-align: left;
    padding: 0.5em 0.75em;
    border-bottom: 1px solid rgb(var(--gray-light));
  }
  th {
    font-size: 0.85em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(var(--gray));
  }
  pre {
    background: rgb(var(--gray-light));
    padding: 1em;
    border-radius: 6px;
    overflow-x: auto;
  }
  .cta {
    display: flex;
    gap: 1em;
    margin-top: 2.5em;
    padding-top: 1.5em;
    border-top: 1px solid rgb(var(--gray-light));
  }
  .cta a {
    padding: 0.6em 1.2em;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    background: var(--accent);
    color: white;
  }
  .cta a:last-child {
    background: rgb(var(--gray-light));
    color: rgb(var(--gray-dark));
  }
</style>
