---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialStreamCard from '../components/social-stream/SocialStreamCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getVisibleBlogPosts } from '../utils/content-helpers';
import { COMPANY, SOCIAL_LINKS } from '../consts';

const allBlog = await getCollection('blog');
const latestPosts = getVisibleBlogPosts(allBlog).slice(0, 8);

const allProjects = await getCollection('projects');
const projects = allProjects.filter((p) => !p.data.draft);

// Trusted-by logos (matching WP order)
const trustedLogos = [
  { name: 'IKEA', url: '/images/wp/logo-trusted-01.svg' },
  { name: 'Ellos', url: '/images/wp/logo-trusted-02.svg' },
  { name: 'Tobii', url: '/images/wp/logo-trusted-03.svg' },
  { name: 'Klarna', url: '/images/wp/logo-trusted-04.svg' },
  { name: 'Telia', url: '/images/wp/logo-trusted-05.svg' },
  { name: 'H&M', url: '/images/wp/logo-trusted-06.svg' },
  { name: 'BytHjul', url: '/images/wp/logo-trusted-07.svg' },
  { name: 'Fyndiq', url: '/images/wp/logo-trusted-08.svg' },
  { name: 'Västtrafik', url: '/images/wp/logo-trusted-09.svg' },
  { name: 'Tradera', url: '/images/wp/logo-trusted-10.svg' },
  { name: 'Frilans Finans', url: '/images/wp/logo-trusted-11.svg' },
  { name: 'Dagens Nyheter', url: '/images/wp/logo-trusted-12.svg' },
  { name: 'Kairos Future', url: '/images/wp/logo-trusted-13.svg' },
  { name: 'Mr Shoebox', url: '/images/wp/logo-trusted-14.svg' },
  { name: 'Photowall', url: '/images/wp/logo-trusted-15.svg' },
  { name: 'Reco', url: '/images/wp/logo-trusted-16.svg' },
  { name: 'AJ Produkter', url: '/images/wp/logo-trusted-aj.png' },
  { name: 'Treated', url: '/images/wp/logo-trusted-17.svg' },
  { name: 'Regeringskansliet', url: '/images/wp/logo-trusted-18.svg' },
  { name: 'Paylevo', url: '/images/wp/logo-trusted-19.svg' },
  { name: 'Björn Lundén', url: '/images/wp/logo-trusted-20.svg' },
  { name: 'Conversionista!', url: '/images/wp/logo-trusted-21.svg' },
  { name: 'Circle K', url: '/images/wp/logo-trusted-22.svg' },
];

// Service items matching WP
const services = [
  { icon: '/images/wp/icon-strategy.svg', title: 'AI-Powered Digital Strategy', text: 'Understanding your business through AI-enhanced research, customer insight mapping, and data-driven strategic frameworks that reveal what truly drives your customers.' },
  { icon: '/images/wp/icon-ux.svg', title: 'AI-Enhanced UX & Interaction Design', text: 'Creating intuitive experiences where AI agents and humans work together seamlessly — minimizing friction and maximizing conversion through intelligent design.' },
  { icon: '/images/wp/icon-requirements.svg', title: 'AI Requirement Engineering', text: 'Using AI to analyze, validate, and ensure system logic works as intended — catching blind spots and maintaining quality across complex digital products.' },
  { icon: '/images/wp/icon-visual.svg', title: 'AI-Driven Visual Design', text: 'Crafting pixel-perfect responsive experiences with AI-accelerated design workflows and generative tools — extensive attention to detail at unprecedented speed.' },
  { icon: '/images/wp/icon-ai.svg', title: 'AI Agent Psychology', text: 'Building intelligent business systems powered by agent technology — optimizing workflows, automating decisions, and designing how AI agents think and collaborate.' },
  { icon: '/images/wp/icon-development.svg', title: 'AI System Development', text: 'Full-stack development with AI agents embedded in the build process — from code generation to testing and deployment, on any technology platform.' },
];

// Project images mapping
const projectImages: Record<string, string> = {
  'histreamers': '/images/wp/project-histreamers.jpg',
  'goal-envision': '/images/wp/project-goalenvision.jpg',
  'skargardspartner': '/images/wp/project-skargardspartner.png',
  'bythjul': '/images/wp/project-bythjul.jpg',
  'indoor-energy-services': '/images/wp/project-indoor.jpg',
  'eve-adam': '/images/wp/project-eveadam.jpg',
  'fyndiqsvajpen': '/images/wp/project-fyndiqsvajpen.jpg',
};
---

<BaseLayout title="Whiteport — AI-Driven Digital Design Agency Stockholm" description="Whiteport is a digital design agency in Stockholm. We combine UX, strategy and AI to build digital products that make business sense.">
  <!-- Hero Banner — WP exact CSS:
       h1 base: font-weight:300, max-width:90%
       h1@750+: font-size:3.6rem, max-width:100%
       h1@1660+: font-size:5rem
       subtitle base: line-height:1.5, max-width:90%
       subtitle@750+: max-width:63.5rem
       subtitle@1660+: font-size:2.4rem
       hero: min-h:765px, pt:80px, pb:110px
       arrow: 50x50, bg:#043F76
       header: padding:30px 0, z-100, fixed -->
  <section class="hero-section relative text-white flex flex-col items-center justify-center min-h-[90vh] pt-[100px] pb-[100px] overflow-hidden bg-cover bg-center bg-no-repeat" style="background-image: url('/images/wp/hero-bg.jpg');">
    <div class="absolute inset-0 bg-wp-blue/65"></div>
    <div class="hero-content relative max-w-[855px] mx-auto px-[15px] text-center flex flex-col items-center gap-[16px]">
      <img src="/images/wp/emblem.png" alt="" class="hero-emblem w-[50px] h-[50px] mb-[14px]" width="50" height="50" />
      <h1 class="max-w-[90%] font-light text-white leading-[1.2] hero-title">
        Digital design powered by Ai that makes business sense.
      </h1>
      <p class="max-w-[90%] text-white leading-[1.5] font-light hero-text">
        Whiteport is a charming digital agency passionate about saving the world, one digital design project at a time. Our methods unify strategic thinking, UX, visual design and AI technology.
      </p>
    </div>
    <!-- Scroll CTA — matches WP hero-banner__btn -->
    <a href="#agency" class="hero-btn absolute bottom-[36px] flex flex-col items-center gap-[12px] text-white hover:text-white/80 transition-colors no-underline" aria-label="Scroll to learn more">
      <img src="/images/wp/hero-phrase.svg" alt="Let us show you how!" class="hero-phrase h-[22px] max-w-[155px] w-auto object-contain" />
      <div class="hero-arrow w-[30px] h-[30px] bg-wp-blue rounded-full flex items-center justify-center">
        <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </div>
    </a>
  </section>

  <!-- Agency — matches WP .icons-block.bg-img with decorative background -->
  <section id="agency" class="agency-section relative py-20 sm:py-28 overflow-hidden" style="background-color: #F6F8FA;">
    <div class="page-width-short">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-light text-center mb-16">Digital business design agency</h2>
      <ul class="grid grid-cols-1 md:grid-cols-3 gap-9 list-none m-0 p-0">
        <li class="text-center">
          <div class="flex items-center justify-center mb-5">
            <img src="/images/wp/icon-analytics.svg" alt="" class="w-16 h-16" />
          </div>
          <h3 class="text-lg font-medium mb-3">Concept & design combining vision with purpose</h3>
          <p class="text-wp-grey text-sm leading-relaxed">
            We bring structure to complexity. With vision and a sharp eye for user experience, we turn ideas into impactful designs that look and feel just right — delivering clarity, elegance, and return on investment.
          </p>
        </li>
        <li class="text-center">
          <div class="flex items-center justify-center mb-5">
            <img src="/images/wp/icon-agreement.svg" alt="" class="w-16 h-16" />
          </div>
          <h3 class="text-lg font-medium mb-3">Adding business sense to your digital presence</h3>
          <p class="text-wp-grey text-sm leading-relaxed">
            We combine strategic insight and real user research with a product mindset. The result? Less chaos, more clarity — and digital solutions that turn ambition into real, measurable progress.
          </p>
        </li>
        <li class="text-center">
          <div class="flex items-center justify-center mb-5">
            <img src="/images/wp/icon-develop.svg" alt="" class="w-16 h-16" />
          </div>
          <h3 class="text-lg font-medium mb-3">Whiteport Design Studio (WDS)</h3>
          <p class="text-wp-grey text-sm leading-relaxed mb-4">
            AI Agent framework for designers based on BMAD method. Gives every designer access to a free and open source platform for Digital Design, Strategy, Trigger mapping, Scenario sketching and handover to development.
          </p>
          <a href="/wds/" class="text-sm font-medium text-[#124e86] underline">Learn more about WDS</a>
        </li>
      </ul>

      <!-- Trusted By — inside agency section, matching WP .icons-block__logos -->
      <div class="mt-20">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-light text-center mb-10">Trusted by</h2>
        <div class="flex flex-wrap justify-center items-center gap-x-[40px] gap-y-[30px]">
          {trustedLogos.map((client) => (
            <img
              src={client.url}
              alt={client.name}
              class="w-[160px] h-[60px] object-contain grayscale"
              loading="lazy"
            />
          ))}
        </div>
      </div>

      <!-- Agency footer link — matches WP .icons-block CTA -->
      <div class="flex items-center justify-center gap-4 mt-16">
        <span class="w-10 h-10 rounded-full bg-[#D74560] flex items-center justify-center flex-shrink-0">
          <img src="/images/wp/icon-calendar.svg" alt="" class="w-5 h-5" />
        </span>
        <a href="https://cal.com/whiteport" target="_blank" rel="noopener noreferrer" class="text-sm font-medium uppercase tracking-[0.08em] text-[#124e86] underline">Lets connect and talk further! — Book a free consultation with me!</a>
      </div>
    </div>
  </section>

  <!-- Projects — matches WP .portfolio-block -->
  {projects.length > 0 && (
    <section id="projects" class="py-20 sm:py-28">
      <div class="page-width-short">
        <h2 class="text-2xl sm:text-3xl font-light text-center text-wp-grey mb-16">Selected Project Case Studies</h2>
        <div class="flex flex-wrap gap-x-[30px] gap-y-[38px]">
          {projects.map((project) => {
            const imgSrc = projectImages[project.id] || project.data.featuredImage?.src;
            return (
              <a href={`/projects/${project.id}/`} class="group block w-full sm:w-[calc(50%-15px)] lg:w-[calc(33.333%-20px)] bg-white overflow-hidden no-underline">
                {imgSrc && (
                  <div class="h-[200px] overflow-hidden">
                    <img
                      src={imgSrc}
                      alt={project.data.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="py-4">
                  <h3 class="text-lg font-medium mb-1 group-hover:text-wp-button transition-colors">{project.data.title}</h3>
                  <p class="text-sm text-wp-grey line-clamp-2">{project.data.description}</p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="text-center mt-12">
          <a href="/projects/" class="inline-block px-8 py-3 bg-wp-blue text-white font-medium rounded hover:-translate-y-0.5 hover:shadow-lg transition-all no-underline uppercase text-sm tracking-wide">
            See all projects
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Services — matches WP .icons-block.bg-color with RED background -->
  <section id="services" class="py-20 sm:py-28" style="background-color: #ea345d;">
    <div class="page-width-short">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-light text-center text-white mb-4">25 years of UX meets bleeding edge AI technology</h2>
      <p class="text-center text-white/70 font-light mb-16">Our services</p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-9 list-none m-0 p-0">
        {services.map((service) => (
          <li class="text-center text-white">
            <div class="w-24 h-24 rounded-[2rem] flex items-center justify-center mx-auto mb-5" style="background-color: #d41b45;">
              <img src={service.icon} alt="" class="w-12 h-12 brightness-0 invert" />
            </div>
            <h3 class="text-lg font-medium mb-2 text-white">{service.title}</h3>
            <p class="text-white/80 text-base font-light leading-relaxed">{service.text}</p>
          </li>
        ))}
      </ul>
      <div class="text-center mt-12">
        <a href="https://cal.com/whiteport" target="_blank" rel="noopener noreferrer" class="inline-block px-8 py-3 bg-white text-wp-blue font-medium rounded hover:-translate-y-0.5 hover:shadow-lg transition-all no-underline">
          Let's talk about your project — Book a meeting!
        </a>
      </div>
    </div>
  </section>

  <!-- Latest from Blog/Stream -->
  <section class="py-20 sm:py-28">
    <div class="page-width-short">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-light text-center mb-16">Follow us on social media!</h2>
      <div class="columns-1 sm:columns-2 lg:columns-4 gap-6 [&>*]:mb-6 [&>*]:break-inside-avoid">
        {latestPosts.map((post) => (
          <SocialStreamCard post={post} />
        ))}
      </div>
      <div class="flex items-center justify-center gap-6 mt-12">
        <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="text-wp-grey hover:-translate-y-0.5 transition-all no-underline" aria-label="LinkedIn">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={SOCIAL_LINKS.facebook} target="_blank" rel="noopener noreferrer" class="text-wp-grey hover:-translate-y-0.5 transition-all no-underline" aria-label="Facebook">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" class="text-wp-grey hover:-translate-y-0.5 transition-all no-underline" aria-label="Instagram">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href="https://www.youtube.com/@whiteport" target="_blank" rel="noopener noreferrer" class="text-wp-grey hover:-translate-y-0.5 transition-all no-underline" aria-label="YouTube">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.tiktok.com/@whiteport" target="_blank" rel="noopener noreferrer" class="text-wp-grey hover:-translate-y-0.5 transition-all no-underline" aria-label="TikTok">
          <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Solutions — matches WP .courses-block -->
  <section id="solutions" class="py-20 sm:py-28 bg-white">
    <div class="page-width-short">
      <h2 class="text-xl sm:text-2xl lg:text-3xl font-light text-center mb-4">
        Whiteport's solutions for enabling marketing and business development
      </h2>
      <p class="text-wp-grey text-center max-w-3xl mx-auto mb-16 text-sm">
        We've seen patterns emerge from our clients. Even though each company is unique, many of the challenges are similar. To address this, we've created our own apps, solutions and methods.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="flex flex-col items-center text-center">
          <img src="/images/wp/solution-social-plugin.png" alt="Social Stream Plugin" class="w-full h-auto mb-4 rounded" />
          <h3 class="text-lg font-medium mb-2">Social Stream Plugin</h3>
          <p class="text-sm text-wp-grey leading-relaxed mb-4">Content operations platform that makes your social media workflow smarter and more efficient.</p>
          <a href="https://whiteport.com/social-stream/" class="mt-auto inline-block px-6 py-2 bg-wp-blue text-white text-sm font-medium rounded hover:-translate-y-0.5 hover:shadow-lg transition-all no-underline">
            WordPress Plugin
          </a>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-full aspect-[4/3] bg-wp-section-bg rounded flex items-center justify-center mb-4">
            <svg class="w-12 h-12 text-wp-grey/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium mb-2">Contract Plugin</h3>
          <p class="text-sm text-wp-grey leading-relaxed mb-4">Become better at leading digital projects and negotiating with your consultants.</p>
          <a href="https://whiteport.com/contracts/" class="mt-auto inline-block px-6 py-2 bg-wp-blue text-white text-sm font-medium rounded hover:-translate-y-0.5 hover:shadow-lg transition-all no-underline">
            WordPress Plugin
          </a>
        </div>
        <div class="flex flex-col items-center text-center">
          <img src="/images/wp/solution-course-tablet.svg" alt="Lines of Thinking" class="w-full h-auto mb-4" />
          <h3 class="text-lg font-medium mb-2">Lines of Thinking</h3>
          <p class="text-sm text-wp-grey leading-relaxed mb-4">Learn how to use hand-drawn sketches as a powerful collaboration tool for concept development and AI prompting.</p>
          <a href="https://whiteport.com/lines-of-thinking/" class="mt-auto inline-block px-6 py-2 bg-wp-blue text-white text-sm font-medium rounded hover:-translate-y-0.5 hover:shadow-lg transition-all no-underline">
            Online Course
          </a>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-full aspect-[4/3] bg-wp-cta/10 rounded flex items-center justify-center mb-4">
            <svg class="w-12 h-12 text-wp-cta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
            </svg>
          </div>
          <h3 class="text-lg font-medium mb-2">Whiteport Design Studio</h3>
          <p class="text-sm text-wp-grey leading-relaxed mb-4">WDS gives you expert AI agents who guide you through strategy and design to make impactful deliveries.</p>
          <a href="/wds/" class="mt-auto inline-block px-6 py-2 bg-wp-cta text-white text-sm font-medium rounded hover:-translate-y-0.5 hover:shadow-lg transition-all no-underline">
            Sketch to Code!
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Team / Contact — matches WP .team-block with dark overlay -->
  <section id="team" class="relative py-20 sm:py-28 text-white bg-cover bg-center bg-no-repeat" style="background-image: url('/images/wp/team-bg.jpg');">
    <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(0,64,123,0.74), rgba(0,64,123,0.74)), linear-gradient(180deg, rgba(0,0,0,0.75) 9.56%, transparent 86.5%);"></div>
    <div class="relative z-10 page-width-short">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-light text-center text-white mb-16">Contact us</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Left: About + Contact -->
        <div class="space-y-8">
          <div>
            <h3 class="text-base font-medium text-white mb-3">About us</h3>
            <p class="text-white/80 text-sm leading-relaxed">
              Whiteport was founded 2003 by Mårten Angner and has been successfully serving clients with sites, apps and e-commerce applications ever since. We focus on innovative solutions, smooth interfaces, neat and minimalistic design.
            </p>
          </div>
          <div>
            <h3 class="text-base font-medium text-white mb-3">For any inquiries contact us</h3>
            <p class="text-white/80 text-sm leading-relaxed">
              We provide excellent strategies and design. Interested in talking about your project? Send us a message and let us schedule a conversation. We'd love to hear about your ideas and project.
            </p>
          </div>
          <div>
            <h3 class="text-base font-medium text-white mb-3">Contacts</h3>
            <p class="text-white/80 text-sm leading-relaxed">
              <a href={COMPANY.mapsUrl} target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white no-underline">{COMPANY.address}</a><br />
              <a href={`mailto:${COMPANY.email}`} class="text-white/80 hover:text-white no-underline">{COMPANY.email}</a>
            </p>
          </div>
        </div>
        <!-- Right: Team members -->
        <div class="flex flex-col sm:flex-row items-center sm:items-start justify-center gap-12">
          {COMPANY.team.map((member) => (
            <div class="text-center">
              <img
                src={member.name === 'Mårten Angner' ? '/images/wp/team-marten.jpg' : '/images/wp/team-anna.jpg'}
                alt={member.name}
                class="w-48 h-48 rounded-full object-cover mx-auto mb-4"
                loading="lazy"
              />
              <h3 class="text-base font-medium text-white">{member.name}</h3>
              <p class="text-white/70 text-sm">{member.title}</p>
              <p class="text-white/70 text-sm mt-1">
                <a href={`mailto:${member.email}`} class="text-white/70 hover:text-white no-underline">{member.email}</a><br />
                <a href={`tel:${member.phone}`} class="text-white/70 hover:text-white no-underline">{member.phone}</a>
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
