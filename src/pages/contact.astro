---
import BaseLayout from '../layouts/BaseLayout.astro';
import { COMPANY, SOCIAL_LINKS } from '../consts';
---

<BaseLayout title="Contact — Book a Free Design Consultation" description="Get in touch with Whiteport. Digital design powered by AI that makes business sense.">
  <section class="py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="text-center mb-16">
        <h1 class="text-3xl sm:text-4xl font-bold mb-4">Get in touch</h1>
        <p class="text-wp-grey max-w-2xl mx-auto">
          Want to discuss a project or learn more about our services? We'd love to hear from you.
        </p>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact info -->
        <div>
          <div class="bg-wp-section-bg rounded-xl p-8 mb-8">
            <h2 class="text-xl font-semibold mb-6">Contact details</h2>
            <div class="space-y-6">
              <div>
                <h3 class="text-sm font-semibold text-wp-grey uppercase tracking-wider mb-1">Email</h3>
                <a href={`mailto:${COMPANY.email}`} class="text-wp-button hover:text-wp-button-hover text-lg no-underline">
                  {COMPANY.email}
                </a>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-wp-grey uppercase tracking-wider mb-1">Address</h3>
                <a href={COMPANY.mapsUrl} target="_blank" rel="noopener noreferrer" class="text-wp-base hover:text-wp-button no-underline">
                  {COMPANY.address}
                </a>
              </div>
              <div>
                <h3 class="text-sm font-semibold text-wp-grey uppercase tracking-wider mb-1">Location</h3>
                <p class="text-wp-base">{COMPANY.location}</p>
              </div>
            </div>
          </div>

          <!-- Social -->
          <div class="bg-wp-section-bg rounded-xl p-8">
            <h2 class="text-xl font-semibold mb-6">Follow us</h2>
            <div class="flex gap-4">
              <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-wp-blue/10 rounded-xl flex items-center justify-center text-wp-blue hover:bg-wp-blue hover:text-white transition-colors no-underline" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
              <a href={SOCIAL_LINKS.facebook} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-wp-blue/10 rounded-xl flex items-center justify-center text-wp-blue hover:bg-wp-blue hover:text-white transition-colors no-underline" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-wp-blue/10 rounded-xl flex items-center justify-center text-wp-blue hover:bg-wp-blue hover:text-white transition-colors no-underline" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Team -->
        <div>
          <h2 class="text-xl font-semibold mb-6">Our team</h2>
          <div class="space-y-6">
            {COMPANY.team.map((member) => (
              <div class="bg-white border border-gray-100 rounded-xl p-6">
                <div class="flex items-start gap-4">
                  <div class="w-14 h-14 bg-wp-blue/10 rounded-full flex items-center justify-center flex-shrink-0">
                    <span class="text-lg font-bold text-wp-blue">{member.name.split(' ').map(n => n[0]).join('')}</span>
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold mb-1">{member.name}</h3>
                    <p class="text-sm text-wp-grey mb-3">{member.title}</p>
                    <div class="space-y-1 text-sm">
                      <a href={`mailto:${member.email}`} class="block text-wp-button hover:text-wp-button-hover no-underline">{member.email}</a>
                      <a href={`tel:${member.phone}`} class="block text-wp-grey hover:text-wp-base no-underline">{member.phone}</a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Hire CTA -->
          <div class="mt-8 bg-wp-blue rounded-xl p-8 text-center">
            <h3 class="text-xl font-semibold text-white mb-3">Ready to start a project?</h3>
            <p class="text-white/75 mb-6 text-sm">We take international projects and strategic design challenges.</p>
            <a
              href={`mailto:${COMPANY.email}`}
              class="inline-block px-8 py-3 bg-wp-cta text-white font-semibold rounded-lg hover:bg-wp-cta-hover transition-colors no-underline"
            >
              Hire us for your projects!
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
