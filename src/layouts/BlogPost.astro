---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_URL, COMPANY } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, categories, tags } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = heroImage ? new URL(heroImage, Astro.site).href : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(description && { description }),
  ...(ogImage && { image: ogImage }),
  url: canonicalURL.href,
  datePublished: pubDate?.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Person', name: author || COMPANY.founder },
  publisher: {
    '@type': 'Organization',
    name: COMPANY.name,
    url: SITE_URL,
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} | ${SITE_TITLE}`}
      description={description || title}
      image={ogImage}
      type="article"
      publishDate={pubDate}
      updatedDate={updatedDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </head>
  <body>
    <Header />
    <main id="main-content" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <article>
        {heroImage && (
          <div class="mb-8">
            <Image width={1020} height={510} src={heroImage} alt="" class="rounded-lg w-full" />
          </div>
        )}
        <div class="prose mx-auto">
          <header class="mb-8 text-center">
            {pubDate && (
              <p class="text-sm text-wp-grey mb-2">
                <FormattedDate date={pubDate} />
                {updatedDate && (
                  <span class="italic">
                    {' '}(updated <FormattedDate date={updatedDate} />)
                  </span>
                )}
              </p>
            )}
            <h1 class="text-3xl sm:text-4xl font-bold">{title}</h1>
            {author && (
              <p class="text-sm text-wp-grey mt-2">By {author}</p>
            )}
          </header>
          <slot />
        </div>

        {/* Tags */}
        {((tags && tags.length > 0) || (categories && categories.length > 0)) && (
          <div class="mt-10 pt-6 border-t border-gray-100 max-w-prose mx-auto">
            <div class="flex flex-wrap gap-2">
              {(categories || []).map((cat: string) => (
                <a href={`/tags/${encodeURIComponent(cat)}/`} class="text-xs px-3 py-1 bg-wp-blue/10 text-wp-blue rounded-full font-medium hover:bg-wp-blue hover:text-white transition-colors no-underline">
                  {cat}
                </a>
              ))}
              {(tags || []).map((tag: string) => (
                <a href={`/tags/${encodeURIComponent(tag)}/`} class="text-xs px-3 py-1 bg-wp-section-bg text-wp-grey rounded-full hover:bg-wp-blue hover:text-white transition-colors no-underline">
                  {tag}
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    </main>
    <Footer />
  </body>
</html>
