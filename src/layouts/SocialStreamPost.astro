---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SocialStreamGallery from '../components/social-stream/SocialStreamGallery.astro';
import { SITE_TITLE, SITE_URL, COMPANY } from '../consts';
import { resolveMediaSrc } from '../utils/content-helpers';

interface Offer {
  title: string;
  description?: string;
  href: string;
}

interface Props {
  title: string;
  publishDate?: Date;
  author?: string;
  categories?: string[];
  locations?: string[];
  mentions?: string[];
  gallery?: any[];
  creativeNote?: string;
  offers?: Offer[];
  allTags?: string[];
}

const { title, publishDate, author, categories = [], locations = [], mentions = [], gallery = [], creativeNote, offers = [], allTags = [] } = Astro.props;

// OG image from first gallery item
const firstImage = gallery.length > 0 ? gallery[0] : null;
const ogImage = firstImage && firstImage.type !== 'video' ? resolveMediaSrc(firstImage) : undefined;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(creativeNote && { description: creativeNote }),
  ...(ogImage && { image: new URL(ogImage, Astro.site).href }),
  url: canonicalURL.href,
  ...(publishDate && { datePublished: publishDate.toISOString() }),
  author: { '@type': 'Person', name: COMPANY.founder },
  publisher: {
    '@type': 'Organization',
    name: COMPANY.name,
    url: SITE_URL,
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};

const hasOffers = offers.length > 0;
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} | Blog | ${SITE_TITLE}`}
      description={creativeNote || title}
      image={ogImage}
      type="article"
      publishDate={publishDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header solid />
    <!-- Full-width hero area: breadcrumb, title, tags, gallery -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32">
      <!-- Breadcrumb — centered gray pill, matches WP -->
      <div class="text-center mb-10">
        <nav class="inline-block text-[11.4px] text-[#999] bg-[#f0f0f0] rounded-full px-5 py-[7px]">
          <a href="/" class="hover:text-wp-blue no-underline text-[#999]">Home</a>
          <span class="mx-1">/</span>
          <a href="/blog/" class="hover:text-wp-blue no-underline text-[#999]">Blog</a>
          <span class="mx-1">/</span>
          <span class="text-[#666]">{title}</span>
        </nav>
      </div>

      <!-- Gallery — full width, above headline -->
      {gallery.length > 0 && (
        <div class="mb-12">
          <SocialStreamGallery items={gallery} />
        </div>
      )}

      <!-- Header — below image -->
      <header class="mb-8">
        <h1 class="text-[48px] leading-[54px] font-light text-[#2e2e2e] mb-6">{title}</h1>

        <!-- Meta row: date, author, tags — same size, different colors -->
        <div class="flex flex-wrap items-center gap-2">
          {publishDate && (
            <span class="inline-block text-xs text-[#666] bg-[#f0f0f0] rounded-full px-4 py-1.5">
              <FormattedDate date={publishDate} />
            </span>
          )}
          {author && (
            <span class="inline-block text-xs text-[#555] bg-[#e8e8e8] rounded-full px-4 py-1.5">
              {author}
            </span>
          )}
          {categories.map((cat) => (
            <a
              href={`/blog/?category=${cat}`}
              class="inline-block text-xs text-wp-blue bg-wp-blue/10 rounded-full px-4 py-1.5 no-underline hover:bg-wp-blue/20"
            >
              {cat}
            </a>
          ))}
          {locations.map((loc) => (
            <span class="inline-block text-xs text-wp-grey bg-wp-section-bg rounded-full px-4 py-1.5">
              {loc}
            </span>
          ))}
        </div>
      </header>
    </div>

    <!-- Content area: article + sidebar below the hero -->
    <main id="main-content" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex-1">
      <div class:list={[hasOffers && 'lg:grid lg:grid-cols-[1fr_280px] lg:gap-10']}>
        <!-- Article column -->
        <article class="min-w-0">

          <!-- Creative note -->
          {creativeNote && (
            <blockquote class="border-l-4 border-wp-red pl-4 mb-8 italic text-wp-grey">
              {creativeNote}
            </blockquote>
          )}

          <!-- Post content -->
          <div class="prose">
            <slot />
          </div>

          <!-- Mentions -->
          {mentions.length > 0 && (
            <div class="mt-8 pt-4 border-t border-wp-section-bg">
              <p class="text-sm text-wp-grey">
                <span class="font-medium">Mentions:</span>{' '}
                {mentions.join(', ')}
              </p>
            </div>
          )}

          <!-- After content slot (sharing, social links, etc.) -->
          <slot name="after-content" />
        </article>

        <!-- Sidebar -->
        {hasOffers && (
          <aside class="hidden lg:block">
            <div class="sticky top-8 space-y-6">
              {offers.map((offer) => (
                <a href={offer.href} class="block p-5 rounded-xl border border-gray-100 bg-white hover:shadow-md transition-shadow no-underline group">
                  <h4 class="text-sm font-semibold text-wp-base group-hover:text-wp-blue transition-colors mb-2">{offer.title}</h4>
                  {offer.description && (
                    <p class="text-xs text-wp-grey leading-relaxed mb-3">{offer.description}</p>
                  )}
                  <span class="text-xs font-medium text-wp-blue">Learn more &rarr;</span>
                </a>
              ))}

              <!-- WDS promo -->
              <a href="/wds/" class="block p-5 rounded-xl bg-wp-blue text-white no-underline hover:bg-wp-blue/90 transition-colors">
                <h4 class="text-sm font-semibold mb-2">Whiteport Design Studio</h4>
                <p class="text-xs text-white/80 leading-relaxed mb-3">AI-powered design method for digital teams. Strategy, UX, and visual design — unified.</p>
                <span class="text-xs font-medium text-white/90">Explore WDS &rarr;</span>
              </a>

              <!-- Contact CTA -->
              <div class="p-5 rounded-xl bg-wp-section-bg">
                <h4 class="text-sm font-semibold text-wp-base mb-2">Let's talk</h4>
                <p class="text-xs text-wp-grey leading-relaxed mb-3">Have a project in mind? We'd love to hear from you.</p>
                <a href="/contact/" class="text-xs font-medium text-wp-blue no-underline hover:underline">Get in touch &rarr;</a>
              </div>
            </div>
          </aside>
        )}
      </div>
    </main>
    <!-- Below-main slot (navigation, related posts) -->
    <slot name="below-main" />
    <Footer />
  </body>
</html>
