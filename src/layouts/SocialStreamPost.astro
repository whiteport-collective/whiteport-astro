---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SocialStreamGallery from '../components/social-stream/SocialStreamGallery.astro';
import { SITE_TITLE, SITE_URL, COMPANY } from '../consts';
import { resolveMediaSrc } from '../utils/content-helpers';

interface Offer {
  title: string;
  description?: string;
  href: string;
}

interface Props {
  title: string;
  seoTitle?: string;
  publishDate?: Date;
  author?: string;
  categories?: string[];
  locations?: string[];
  mentions?: string[];
  gallery?: any[];
  creativeNote?: string;
  offers?: Offer[];
  allTags?: string[];
}

const { title, seoTitle, publishDate, author, categories = [], locations = [], mentions = [], gallery = [], creativeNote, offers = [], allTags = [] } = Astro.props;

// Hero gallery: only items with 'gallery' in display, or all if none specified
const heroGallery = gallery.filter(g => g.display?.includes('gallery')) || [];
const displayGallery = heroGallery.length > 0 ? heroGallery : gallery;

// OG image from first gallery item
const firstImage = gallery.length > 0 ? gallery[0] : null;
const ogImage = firstImage && firstImage.type !== 'video' ? resolveMediaSrc(firstImage) : undefined;

// Portrait mode: when hero image is taller than wide, use 3-column layout with sticky image
const heroImage = displayGallery[0];
const isPortraitHero = !!(heroImage && heroImage.type !== 'video' && heroImage.width && heroImage.height && heroImage.height > heroImage.width);
const portraitImageSrc = isPortraitHero ? resolveMediaSrc(heroImage) : null;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(creativeNote && { description: creativeNote }),
  ...(ogImage && { image: new URL(ogImage, Astro.site).href }),
  url: canonicalURL.href,
  ...(publishDate && { datePublished: publishDate.toISOString() }),
  author: { '@type': 'Person', name: COMPANY.founder },
  publisher: {
    '@type': 'Organization',
    name: COMPANY.name,
    url: SITE_URL,
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};

const hasOffers = offers.length > 0;
---

<html lang="en">
  <head>
    <BaseHead
      title={seoTitle || `${title} | Blog | ${SITE_TITLE}`}
      description={creativeNote || title}
      image={ogImage}
      type="article"
      publishDate={publishDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header solid />
    <!-- Breadcrumb — full width, centered -->
    <div class:list={["mx-auto px-4 sm:px-6 lg:px-8 pt-32", isPortraitHero ? "max-w-[1800px]" : "max-w-7xl"]}>
      <div class="text-center mb-10">
        <nav class="inline-block text-[11.4px] text-[#999] bg-[#f0f0f0] rounded-full px-5 py-[7px]">
          <a href="/" class="hover:text-wp-blue no-underline text-[#999]">Home</a>
          <span class="mx-1">/</span>
          <a href="/blog/" class="hover:text-wp-blue no-underline text-[#999]">Blog</a>
          <span class="mx-1">/</span>
          <span class="text-[#666]">{title}</span>
        </nav>
      </div>

      {!isPortraitHero && displayGallery.length > 0 && (
        <!-- Gallery — full width, above headline (landscape hero) -->
        <div class="mb-12">
          <SocialStreamGallery items={displayGallery} />
        </div>
      )}

      <!-- Header — full width, always above content/image grid -->
      <header class="mb-16 lg:mb-20 text-center">
        <h1 class="text-[40px] leading-[48px] lg:text-[56px] lg:leading-[62px] font-light text-[#2e2e2e] mb-6">{title}</h1>

        <!-- Meta row: date, author, tags -->
        <div class="flex flex-wrap items-center justify-center gap-2">
          {publishDate && (
            <span class="inline-block text-xs text-[#666] bg-[#f0f0f0] rounded-full px-4 py-1.5">
              <FormattedDate date={publishDate} />
            </span>
          )}
          {author && (
            <span class="inline-block text-xs text-[#555] bg-[#e8e8e8] rounded-full px-4 py-1.5">
              {author}
            </span>
          )}
          {categories.map((cat) => (
            <a
              href={`/blog/?category=${cat}`}
              class="inline-block text-xs text-wp-blue bg-wp-blue/10 rounded-full px-4 py-1.5 no-underline hover:bg-wp-blue/20"
            >
              {cat}
            </a>
          ))}
          {locations.map((loc) => (
            <span class="inline-block text-xs text-wp-grey bg-wp-section-bg rounded-full px-4 py-1.5">
              {loc}
            </span>
          ))}
        </div>
      </header>
    </div>

    <!-- Content area: article + sidebar below the hero -->
    <main id="main-content" class:list={["mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex-1", isPortraitHero ? "max-w-[1800px]" : "max-w-7xl"]}>
      <div class:list={[
        isPortraitHero
          ? (hasOffers
              ? 'lg:grid lg:grid-cols-[minmax(280px,420px)_minmax(0,1fr)] xl:grid-cols-[minmax(320px,460px)_minmax(0,1fr)_280px] lg:gap-10'
              : 'lg:grid lg:grid-cols-[minmax(280px,420px)_minmax(0,1fr)] lg:gap-10')
          : (hasOffers && 'lg:grid lg:grid-cols-[1fr_280px] lg:gap-10')
      ]}>

        <!-- Portrait hero column: sticky image (desktop only; mobile shows image above content) -->
        {isPortraitHero && (
          <aside class="mb-8 lg:mb-0">
            <div class="lg:sticky lg:top-24">
              <img
                src={portraitImageSrc}
                alt={heroImage?.alt || title}
                class="w-full h-auto lg:max-h-[calc(100vh-8rem)] lg:w-auto lg:mx-auto rounded-lg object-contain"
                loading="eager"
              />
            </div>
          </aside>
        )}

        <!-- Article column -->
        <article class="min-w-0">

          <!-- Creative note -->
          {creativeNote && (
            <blockquote class="border-l-4 border-wp-red pl-4 mb-8 italic text-wp-grey">
              {creativeNote}
            </blockquote>
          )}

          <!-- Post content -->
          <div class="prose">
            <slot />
          </div>

          <!-- Mentions -->
          {mentions.length > 0 && (
            <div class="mt-8 pt-4 border-t border-wp-section-bg">
              <p class="text-sm text-wp-grey">
                <span class="font-medium">Mentions:</span>{' '}
                {mentions.join(', ')}
              </p>
            </div>
          )}

          <!-- After content slot (sharing, social links, etc.) -->
          <slot name="after-content" />
          <slot name="after-content-nav" />
        </article>

        <!-- Sidebar -->
        {hasOffers && (
          <aside class="hidden xl:block">
            <div class="sticky top-24 space-y-6">
              {/* Author photo + CTA — merged into a single black card */}
              {offers[0] && (
                <a href={offers[0].href} class="block no-underline transition-shadow hover:shadow-xl overflow-hidden rounded-xl" style="background:#0a0a0a; color:white;">
                  <div style="position:relative;">
                    <img
                      src="/images/team/marten-cv.jpg"
                      alt={COMPANY.founder}
                      class="w-full block"
                      style="aspect-ratio: 3/4; object-fit: cover; filter: grayscale(20%) brightness(0.95);"
                      loading="lazy"
                    />
                    {/* Bottom fade into the black card */}
                    <div style="position:absolute; left:0; right:0; bottom:0; height:45%; background:linear-gradient(to bottom, rgba(10,10,10,0) 0%, rgba(10,10,10,0.6) 55%, rgba(10,10,10,1) 100%); pointer-events:none;"></div>
                  </div>
                  <div style="padding:0 24px 24px 24px; margin-top:-40px; position:relative; z-index:1;">
                    {offers[0].label && (
                      <p style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:rgba(255,255,255,0.5); margin:0 0 10px 0;">{offers[0].label}</p>
                    )}
                    <h4 style="font-size:18px; font-weight:600; line-height:1.4; color:white; margin:0 0 10px 0;">{offers[0].title}</h4>
                    {offers[0].description && (
                      <p style="font-size:14px; font-weight:300; line-height:1.7; color:rgba(255,255,255,0.85); margin:0 0 14px 0; white-space:pre-line;">{offers[0].description}</p>
                    )}
                    <span style="font-size:14px; font-weight:600; color:white; background:rgba(255,255,255,0.12); padding:8px 16px; border-radius:6px; display:block; text-align:center;">{offers[0].cta || 'Learn more →'}</span>
                  </div>
                </a>
              )}

              {/* Author card — right after CTA */}
              <div class="pt-2">
                <p style="font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.08em; color:#999; margin:0 0 12px 0;">Written by</p>
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:12px;">
                  <img
                    src="/images/team/marten-angner-cropped-600.png"
                    alt="Mårten Angner"
                    style="width:52px; height:52px; border-radius:50%; object-fit:cover; object-position:center top; flex-shrink:0;"
                  />
                  <div>
                    <p style="font-size:16px; font-weight:600; color:#2e2e2e; margin:0 0 2px 0;">{COMPANY.founder}</p>
                    <p style="font-size:13px; color:#666; margin:0; line-height:1.4;">{COMPANY.founderTitle}</p>
                  </div>
                </div>
                <p style="font-size:14px; color:#555; line-height:1.6; margin:0 0 12px 0;">Founder of Whiteport — helping teams build better digital products with AI-driven design processes.</p>
                <a href="https://www.linkedin.com/in/martenangner/" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-wp-blue no-underline hover:underline inline-flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  Connect on LinkedIn
                </a>
              </div>


              <!-- Share slot (filled from page) -->
              <slot name="sidebar-share" />
            </div>
          </aside>
        )}
      </div>
    </main>
    <!-- Below-main slot (navigation, related posts) -->
    <slot name="below-main" />
    <!-- Toning + CTA + Contact wrapper — no bg on wrapper so toning stays clean -->
    <div style="position:relative; z-index:5; margin-top:-550px; pointer-events:none;">
      <!-- Toning: original gradient, fades grid cards -->
      <div style="height:550px; background: linear-gradient(to bottom, transparent 0%, rgba(246,248,250,0.3) 20%, rgba(246,248,250,0.7) 40%, #F6F8FA 55%); pointer-events:none;"></div>
      <!-- CTA button -->
      <div style="display:flex; justify-content:center; position:relative; z-index:10; margin-top:-200px; padding-bottom:60px; pointer-events:auto;">
        <a href="/blog/" style="display:inline-flex; align-items:center; gap:8px; padding:14px 28px; background:#043F76; color:white; font-size:15px; font-weight:500; border-radius:40px; text-decoration:none; box-shadow:0 2px 8px rgba(4,63,118,0.2);">
          Läs alla relaterade artiklar
          <svg style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
      <!-- Contact / Team — blue section with its own bg -->
      <section id="team" class="relative py-20 sm:py-28 text-white bg-cover bg-center bg-no-repeat" style="background-image: url('/images/wp/team-bg.jpg'); pointer-events:auto;">
        <div class="absolute inset-0" style="background: linear-gradient(0deg, rgba(0,64,123,0.74), rgba(0,64,123,0.74)), linear-gradient(180deg, rgba(0,0,0,0.75) 9.56%, transparent 86.5%);"></div>
        <div class="relative z-10 page-width-short">
          <h2 class="text-2xl sm:text-3xl lg:text-4xl font-light text-center text-white mb-16">Contact us</h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
            <div class="space-y-8">
              <div>
                <h3 class="text-base font-medium text-white mb-3">About us</h3>
                <p class="text-white/80 text-sm leading-relaxed">
                  Whiteport was founded 2003 by Mårten Angner and has been successfully serving clients with sites, apps and e-commerce applications ever since. We focus on innovative solutions, smooth interfaces, neat and minimalistic design.
                </p>
              </div>
              <div>
                <h3 class="text-base font-medium text-white mb-3">For any inquiries contact us</h3>
                <p class="text-white/80 text-sm leading-relaxed">
                  We provide excellent strategies and design. Interested in talking about your project? Send us a message and let us schedule a conversation. We'd love to hear about your ideas and project.
                </p>
              </div>
              <div>
                <h3 class="text-base font-medium text-white mb-3">Contacts</h3>
                <p class="text-white/80 text-sm leading-relaxed">
                  <a href={COMPANY.mapsUrl} target="_blank" rel="noopener noreferrer" class="text-white/80 hover:text-white no-underline">{COMPANY.address}</a><br />
                  <a href={`mailto:${COMPANY.email}`} class="text-white/80 hover:text-white no-underline">{COMPANY.email}</a>
                </p>
              </div>
            </div>
            <div class="flex flex-col sm:flex-row items-center sm:items-start justify-center gap-12">
              {COMPANY.team.map((member) => (
                <div class="text-center">
                  <img
                    src={member.name === 'Mårten Angner' ? '/images/wp/team-marten.jpg' : '/images/wp/team-anna.jpg'}
                    alt={member.name}
                    class="w-48 h-48 rounded-full object-cover mx-auto mb-4"
                    loading="lazy"
                  />
                  <h3 class="text-base font-medium text-white">{member.name}</h3>
                  <p class="text-white/70 text-sm">{member.title}</p>
                  <p class="text-white/70 text-sm mt-1">
                    <a href={`mailto:${member.email}`} class="text-white/70 hover:text-white no-underline">{member.email}</a><br />
                    <a href={`tel:${member.phone}`} class="text-white/70 hover:text-white no-underline">{member.phone}</a>
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>
    </div>
    <Footer />
  </body>
</html>
