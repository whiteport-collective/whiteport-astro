---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SocialStreamGallery from '../components/social-stream/SocialStreamGallery.astro';
import { SITE_TITLE, SITE_URL, COMPANY } from '../consts';
import { resolveMediaSrc } from '../utils/content-helpers';

interface Offer {
  title: string;
  description?: string;
  href: string;
}

interface Props {
  title: string;
  publishDate?: Date;
  categories?: string[];
  locations?: string[];
  mentions?: string[];
  gallery?: any[];
  creativeNote?: string;
  offers?: Offer[];
  allTags?: string[];
}

const { title, publishDate, categories = [], locations = [], mentions = [], gallery = [], creativeNote, offers = [], allTags = [] } = Astro.props;

// OG image from first gallery item
const firstImage = gallery.length > 0 ? gallery[0] : null;
const ogImage = firstImage && firstImage.type !== 'video' ? resolveMediaSrc(firstImage) : undefined;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  ...(creativeNote && { description: creativeNote }),
  ...(ogImage && { image: new URL(ogImage, Astro.site).href }),
  url: canonicalURL.href,
  ...(publishDate && { datePublished: publishDate.toISOString() }),
  author: { '@type': 'Person', name: COMPANY.founder },
  publisher: {
    '@type': 'Organization',
    name: COMPANY.name,
    url: SITE_URL,
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE_URL}/blog/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};

const hasOffers = offers.length > 0;
---

<html lang="en">
  <head>
    <BaseHead
      title={`${title} | Blog | ${SITE_TITLE}`}
      description={creativeNote || title}
      image={ogImage}
      type="article"
      publishDate={publishDate}
    />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  </head>
  <body>
    <Header />
    <main id="main-content" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class:list={[hasOffers && 'lg:grid lg:grid-cols-[1fr_280px] lg:gap-10']}>
        <!-- Article column -->
        <article class="min-w-0">
          <!-- Breadcrumb -->
          <nav class="text-sm text-wp-grey mb-6">
            <a href="/" class="hover:text-wp-blue no-underline">Home</a>
            <span class="mx-1">/</span>
            <a href="/blog/" class="hover:text-wp-blue no-underline">Blog</a>
            <span class="mx-1">/</span>
            <span class="text-wp-base">{title}</span>
          </nav>

          <!-- Header -->
          <header class="mb-8">
            {publishDate && (
              <p class="text-sm text-wp-grey mb-2">
                <FormattedDate date={publishDate} />
              </p>
            )}
            <h1 class="text-3xl sm:text-4xl font-bold mb-4">{title}</h1>

            <!-- Tags row -->
            {(categories.length > 0 || locations.length > 0) && (
              <div class="flex flex-wrap gap-2">
                {categories.map((cat) => (
                  <a
                    href={`/blog/?category=${cat}`}
                    class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-wp-blue/10 text-wp-blue no-underline hover:bg-wp-blue/20"
                  >
                    {cat}
                  </a>
                ))}
                {locations.map((loc) => (
                  <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-wp-section-bg text-wp-grey">
                    {loc}
                  </span>
                ))}
              </div>
            )}
          </header>

          <!-- Gallery -->
          {gallery.length > 0 && (
            <div class="mb-8">
              <SocialStreamGallery items={gallery} />
            </div>
          )}

          <!-- Creative note -->
          {creativeNote && (
            <blockquote class="border-l-4 border-wp-red pl-4 mb-8 italic text-wp-grey">
              {creativeNote}
            </blockquote>
          )}

          <!-- Post content -->
          <div class="prose">
            <slot />
          </div>

          <!-- Mentions -->
          {mentions.length > 0 && (
            <div class="mt-8 pt-4 border-t border-wp-section-bg">
              <p class="text-sm text-wp-grey">
                <span class="font-medium">Mentions:</span>{' '}
                {mentions.join(', ')}
              </p>
            </div>
          )}

          <!-- After content slot (sharing, social links, etc.) -->
          <slot name="after-content" />
        </article>

        <!-- Sidebar -->
        {hasOffers && (
          <aside class="hidden lg:block">
            <div class="sticky top-8 space-y-6">
              {offers.map((offer) => (
                <a href={offer.href} class="block p-5 rounded-xl border border-gray-100 bg-white hover:shadow-md transition-shadow no-underline group">
                  <h4 class="text-sm font-semibold text-wp-base group-hover:text-wp-blue transition-colors mb-2">{offer.title}</h4>
                  {offer.description && (
                    <p class="text-xs text-wp-grey leading-relaxed mb-3">{offer.description}</p>
                  )}
                  <span class="text-xs font-medium text-wp-blue">Learn more &rarr;</span>
                </a>
              ))}

              <!-- WDS promo -->
              <a href="/wds/" class="block p-5 rounded-xl bg-wp-blue text-white no-underline hover:bg-wp-blue/90 transition-colors">
                <h4 class="text-sm font-semibold mb-2">Whiteport Design Studio</h4>
                <p class="text-xs text-white/80 leading-relaxed mb-3">AI-powered design method for digital teams. Strategy, UX, and visual design — unified.</p>
                <span class="text-xs font-medium text-white/90">Explore WDS &rarr;</span>
              </a>

              <!-- Contact CTA -->
              <div class="p-5 rounded-xl bg-wp-section-bg">
                <h4 class="text-sm font-semibold text-wp-base mb-2">Let's talk</h4>
                <p class="text-xs text-wp-grey leading-relaxed mb-3">Have a project in mind? We'd love to hear from you.</p>
                <a href="/contact/" class="text-xs font-medium text-wp-blue no-underline hover:underline">Get in touch &rarr;</a>
              </div>
            </div>
          </aside>
        )}
      </div>
    </main>
    <Footer />
  </body>
</html>
