---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../FormattedDate.astro';
import { resolveMediaSrc, resolveMediaPoster } from '../../utils/content-helpers';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, publishDate, categories, gallery, creativeNote, excerpt } = post.data;
const description = creativeNote || excerpt;
const hasMedia = gallery && gallery.length > 0;
const thumbnailImage = hasMedia ? gallery.find(g => g.display?.includes('thumbnail')) : null;
const firstImage = thumbnailImage || (hasMedia ? gallery[0] : null);
const isVideo = firstImage?.type === 'video';
const isYouTube = !!firstImage?.youtubeId;
// For video cards, use poster thumbnail (lightweight) instead of the video file
const thumbSrc = firstImage
  ? (isVideo ? resolveMediaPoster(firstImage) || resolveMediaSrc(firstImage) : resolveMediaSrc(firstImage))
  : '';
---

<a href={`/blog/${post.id}/`} class="group block no-underline stream-card">
  <article class="bg-white rounded-lg shadow-sm hover:shadow-lg hover:scale-[1.03] transition-all duration-300 overflow-hidden border border-gray-100">
    <!-- Thumbnail — natural aspect ratio, no forced dimensions -->
    {thumbSrc ? (
      <div class="overflow-hidden bg-wp-section-bg relative">
        <img
          src={thumbSrc}
          alt={firstImage?.alt || title}
          class="w-full block"
          loading="eager"
          width={firstImage?.width}
          height={firstImage?.height}
        />
        {isVideo && (
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
            <div class:list={['w-10 h-10 rounded-full flex items-center justify-center', isYouTube ? 'bg-red-600/80' : 'bg-black/50']}>
              <svg class="w-5 h-5 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
        )}
      </div>
    ) : hasMedia ? (
      <div class="aspect-video bg-wp-section-bg flex items-center justify-center">
        <span class="text-wp-grey/40 text-sm">{gallery.length} media</span>
      </div>
    ) : (
      <div class="h-2 bg-gradient-to-r from-wp-blue/20 via-wp-blue/10 to-transparent"></div>
    )}

    <!-- Content -->
    <div class="p-4">
      {categories.length > 0 && (
        <div class="flex flex-wrap gap-1 mb-2">
          {categories.slice(0, 3).map((cat) => (
            <span class="inline-block px-2 py-0.5 text-xs font-medium rounded-full bg-wp-blue/10 text-wp-blue">
              {cat}
            </span>
          ))}
        </div>
      )}

      <h3 class="text-base font-semibold text-wp-base group-hover:text-wp-blue transition-colors line-clamp-2 mb-1">
        {title}
      </h3>

      {publishDate && (
        <p class="text-xs text-wp-grey mb-0">
          <FormattedDate date={publishDate} />
        </p>
      )}

      {description && (
        <p class="text-sm text-wp-grey mt-2 line-clamp-2 mb-0">{description}</p>
      )}
    </div>
  </article>
</a>

<style>
  .stream-card {
    break-inside: avoid;
  }
</style>
