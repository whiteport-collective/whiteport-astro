---
/**
 * RelatedPostsGrid — 2 rows of most similar posts, with fade + CTA.
 */
import type { CollectionEntry } from 'astro:content';
import SocialStreamCard from './SocialStreamCard.astro';

interface Props {
  posts: CollectionEntry<'blog'>[];
  tagCounts: Map<string, number>;
  activeCategory: string;
  currentPostId: string;
  currentTags?: string[];
}

const { posts, activeCategory, currentPostId, currentTags: currentTagsProp } = Astro.props;

// Score by shared tags, then sort by date (newest first within same score)
const currentTags = new Set(currentTagsProp || []);

const scored = posts
  .filter(p => p.id !== currentPostId)
  .map(p => {
    const postTags = [...(p.data.categories || []), ...(p.data.tags || [])];
    const shared = postTags.filter(t => currentTags.has(t)).length;
    return { post: p, shared };
  })
  .filter(s => s.shared > 0) // only posts with matching tags
  .sort((a, b) => b.shared - a.shared || (b.post.data.publishDate?.getTime() || 0) - (a.post.data.publishDate?.getTime() || 0));

// Show max 8 (2 rows × 4 cols on desktop), fill with recent posts if needed
// Show max 8 (2 rows × 4 cols on desktop)
const maxPosts = 9;
const matchedPosts = scored.map(s => s.post).slice(0, maxPosts);
const matchedIds = new Set(matchedPosts.map(p => p.id));
if (matchedPosts.length < maxPosts) {
  const filler = posts
    .filter(p => p.id !== currentPostId && !matchedIds.has(p.id))
    .sort((a, b) => (b.data.publishDate?.getTime() || 0) - (a.data.publishDate?.getTime() || 0))
    .slice(0, maxPosts - matchedPosts.length);
  matchedPosts.push(...filler);
}
const displayPosts = matchedPosts;

// Collect tags that appear in displayed posts, sorted by frequency
const tagFreq = new Map<string, number>();
displayPosts.forEach(p => {
  [...(p.data.categories || []), ...(p.data.tags || [])]
    .filter(t => currentTags.has(t))
    .forEach(t => tagFreq.set(t, (tagFreq.get(t) || 0) + 1));
});
const relatedTags = [...tagFreq.entries()].sort((a, b) => b[1] - a[1]).map(([tag]) => tag);

const blogLink = activeCategory ? `/blog/?filter=${encodeURIComponent(activeCategory)}` : '/blog/';
---

{displayPosts.length > 0 && (
  <section class="related-section bg-wp-section-bg py-16 mt-8" style="padding-bottom:0; position:relative; z-index:0;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 style="font-size:36px; font-weight:300; line-height:1.2; text-align:center; margin-bottom:16px;">Related posts</h2>
      {currentTags.size > 0 && (
        <div style="text-align:center; margin-bottom:40px; display:flex; flex-wrap:wrap; justify-content:center; gap:8px;">
          {[...currentTags].slice(0, 4).map(tag => (
            <a href={`/blog/?filter=${encodeURIComponent(tag)}`} class="inline-block px-4 py-1.5 text-sm font-medium rounded-full bg-wp-blue/10 text-wp-blue no-underline hover:bg-wp-blue hover:text-white transition-colors">{tag}</a>
          ))}
        </div>
      )}

      <div class="related-grid-wrap">
        <div class="related-grid" id="related-grid">
          {displayPosts.map((post) => (
            <div class="related-card">
              <SocialStreamCard post={post} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .related-grid-wrap {
    position: relative;
  }

  .related-grid {
    columns: 2;
    column-gap: 1rem;
  }

  @media (min-width: 1024px) {
    .related-grid { columns: 3; }
  }
  @media (min-width: 1280px) {
    .related-grid { columns: 4; }
  }

  .related-card {
    break-inside: avoid;
    margin-bottom: 1rem;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .related-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

</style>

<script is:inline define:vars={{ relatedGridId: 'related-grid' }}>
  const grid = document.getElementById(relatedGridId);
  if (grid) {
    const cards = Array.from(grid.querySelectorAll('.related-card'));

    let queue = [];
    let draining = false;

    function enqueue(el) {
      queue.push(el);
      if (!draining) { draining = true; drainQueue(); }
    }
    function drainQueue() {
      if (queue.length === 0) { draining = false; return; }
      const el = queue.shift();
      el.classList.add('visible');
      setTimeout(drainQueue, 80);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target.querySelector('img');
            if (!img || img.complete) { enqueue(entry.target); }
            else {
              img.addEventListener('load', () => enqueue(entry.target), { once: true });
              img.addEventListener('error', () => enqueue(entry.target), { once: true });
            }
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );

    cards.forEach(card => observer.observe(card));
  }
</script>
