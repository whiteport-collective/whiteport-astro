---
import { COMPANY, SITE_TITLE, SOCIAL_LINKS } from '../consts';

const year = new Date().getFullYear();
---

<footer id="footer" class="bg-wp-footer-bg text-wp-footer py-10">
  <div class="max-w-[54rem] lg:max-w-[72rem] mx-auto px-6 flex flex-col sm:flex-row items-center sm:items-start justify-between gap-8">
    <!-- Logo -->
    <a href="/" class="no-underline shrink-0">
      <span class="text-sm font-bold tracking-[0.15em] uppercase text-white/60">{SITE_TITLE}</span>
    </a>

    <!-- Address -->
    <div class="text-xs text-white/60 text-center sm:text-left">
      <p>{COMPANY.address}</p>
      <p class="hidden sm:block"><a href={`mailto:${COMPANY.founderEmail}`} class="text-white/60 hover:text-white/80 transition-colors no-underline">{COMPANY.founderEmail}</a></p>
      <p class="sm:hidden">Copyright &copy; {year} {COMPANY.name} AB</p>
    </div>

    <!-- Copyright -->
    <div class="text-xs text-white/60 text-center sm:text-right">
      <p class="sm:hidden"><a href={`mailto:${COMPANY.founderEmail}`} class="text-white/60 hover:text-white/80 transition-colors no-underline">{COMPANY.founderEmail}</a></p>
      <p class="hidden sm:block">Copyright &copy; {year} {COMPANY.name} AB</p>
      <p>All rights reserved</p>
    </div>
  </div>
</footer>
