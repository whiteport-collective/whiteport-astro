# ──────────────────────────────────────────────────────────
# Google Drive Service Account (for astro-gdrive integration)
# ──────────────────────────────────────────────────────────
#
# The astro-gdrive integration downloads media from Google Drive
# at build time. Without a service account, it falls back to
# public endpoints (only works for publicly shared files).
#
# Setup:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or use existing)
# 3. Enable "Google Drive API"
# 4. Go to IAM → Service Accounts → Create Service Account
# 5. Create a key (JSON format) → download the file
# 6. Share your GDrive media folder with the service account email
#    (the email looks like: name@project.iam.gserviceaccount.com)
# 7. Set ONE of the variables below:

# Option A: Paste the full JSON key as a single-line string
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option B: Path to the JSON key file on disk
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/path/to/service-account-key.json

# Shared Drive used by astro-gdrive and ElevenLabs article audio cache.
# The service account needs Content Manager access for audio cache uploads.
GOOGLE_SHARED_DRIVE_NAME="Whiteport Team"

# ──────────────────────────────────────────────────────────
# ElevenLabs article audio (WO-001 Listen To Me)
# ──────────────────────────────────────────────────────────
#
# The astro-elevenlabs integration generates MP3 read-aloud audio and
# word-level alignment JSON at build time. Missing credentials skip audio
# generation gracefully; set ELEVENLABS_STRICT=true to fail instead.
# If an article has mediaFolder frontmatter, generated ElevenLabs MP3/JSON
# are cached in that article's Drive folder. Without mediaFolder, local cache
# in public/audio/ is used only.

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
MAX_AUDIO_PER_BUILD=10
# ELEVENLABS_GENERATE_IN_DEV=true
# ELEVENLABS_STRICT=true

# ──────────────────────────────────────────────────────────
# Deploy credentials (SFTP to Hostup)
# ──────────────────────────────────────────────────────────
DEPLOY_HOST=mu.hostup.se
DEPLOY_PORT=22

# Main account (aiwhitep / websespr)
DEPLOY_USER=
DEPLOY_PASS=

# Astro staging account (astrowhi)
DEPLOY_ASTRO_USER=
DEPLOY_ASTRO_PASS=
